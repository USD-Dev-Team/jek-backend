generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Rollar ro'yxati
enum jekRoles {
  User
  JEK
  Admin
  INSPECTION
  Government
}

// Ariza holatlari
enum Status_Flow {
  PENDING
  IN_PROGRESS
  COMPLETED
  JEK_COMPLETED
  REJECTED
  JEK_REJECTED
}

//  Users modeli

model Users {
  id                String   @id @default(uuid())
  telegram_id       BigInt   @unique
  first_name        String?
  last_name         String?
  phoneNumber       String?  @unique
  role              jekRoles @default(User)
  registration_step String?  @default("START") // START, FIRST_NAME, LAST_NAME, PHONE_NUMBER, COMPLETED, REQ_DISTRICT, REQ_ADDRESS, REQ_DESCRIPTION, REQ_PHOTO, REQ_CONFIRM

  // Vaqtinchalik ariza ma'lumotlari
  temp_district          String?
  temp_mahalla           String?
  temp_street            String?
  temp_house             String?
  temp_address           String?
  temp_description       String?
  temp_photos            Json? // Bir nechta rasmlar uchun file_id massivi
  temp_reject_request_id String? // E'tiroz bildirilayotgan ariza ID-si

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  requests  Requests[]

  @@map("users")
}

// Admin modeli

model Admins {
  id           String   @id @default(uuid())
  first_name   String   @db.VarChar(50)
  last_name    String   @db.VarChar(50)
  password     String   @db.VarChar(255)
  phoneNumber  String   @unique @db.VarChar(20)
  role         jekRoles @default(JEK)
  isActive     Boolean  @default(false)
  refreshToken String?  @db.Text
  jti          String?  @db.VarChar(255)

  addresses Admin_addresses[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedRequests Requests[]

  @@map("admins")
}

// Murojaat modeli (Requests)

model Requests {
  id               String      @id @default(uuid())
  request_number   String      @unique @db.VarChar(20)
  user_id          String
  address_id       String      // Manzil bog'liqligi
  assigned_jek_id  String?
  latitude         Decimal?    @db.Decimal(10, 8)
  longitude        Decimal?    @db.Decimal(11, 8)
  description      String      @db.Text
  status           Status_Flow @default(PENDING)
  note             String?     @db.Text
  rejection_reason String?     @db.Text
  completedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  address           Addresses          @relation(fields: [address_id], references: [id])
  assigned_jek      Admins?            @relation(fields: [assigned_jek_id], references: [id])
  user              Users              @relation(fields: [user_id], references: [id])
  requestPhotos     RequestPhoto[]
  requestStatusLogs RequestStatusLog[]

  @@map("requests")
}

// Murojaat rasmlari (RequestPhotos)

model RequestPhoto {
  id         String   @id @default(uuid())
  request_id String
  request    Requests @relation(fields: [request_id], references: [id], onDelete: Cascade)

  file_url         String  @db.Text
  telegram_file_id String? @db.VarChar(255)
  file_size        Int? // Byte-larda

  created_at DateTime @default(now())

  @@map("request_photos")
}

// Holat o'zgarishi loglari (RequestStatusLog)

model RequestStatusLog {
  id              String      @id @default(uuid())
  request_id      String
  request         Requests    @relation(fields: [request_id], references: [id], onDelete: Cascade)
  old_status      Status_Flow
  new_status      Status_Flow
  changed_by_role String      @db.VarChar(50)
  changed_by_id   String      @db.VarChar(50)
  note            String?     @db.Text
  createdAt       DateTime    @default(now())

  @@map("request_status_logs")
}

// Manzil modeli (Addresses)
// street va house qaysi biri bo'lmasa null bo'ladi

model Addresses {
  id           String   @id @default(uuid())
  district     String   // Tuman (endi String ko'rinishida)
  neighborhood String   // (Dahasi) Mahalla
  street       String?  // Ko'cha
  house        String?  // Uy raqami

  admin_addresses Admin_addresses[]
  requests        Requests[] // Arizalar ro'yxati (bog'landi)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([district, neighborhood, street, house]) // Manzillar takrorlanmasligi uchun
  @@map("addresses")
}

// Admin va adreslar orasidagi bog'lanish (Many-to-Many)

model Admin_addresses {
  id         String @id @default(uuid())
  admin_id   String
  address_id String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  admin   Admins    @relation(fields: [admin_id], references: [id], onDelete: Cascade)
  address Addresses @relation(fields: [address_id], references: [id], onDelete: Cascade)

  @@unique([admin_id, address_id]) // Bitta xodimga bitta mahallani ikki marta biriktirmaslik uchun
  @@map("admin_addresses")
}
