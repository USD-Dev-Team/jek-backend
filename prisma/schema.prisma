generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Rollar ro'yxati
enum jekRoles {
  User
  JEK
  INSPECTION
}

// Ariza holatlari
enum Status_Flow {
  PENDING
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  REJECTED
}

// Sirdaryo viloyati bo'yicha tuman/shaharlar ro'yxati
enum District {
  GULISTON_SHAHAR
  YANGIYER_SHAHAR
  SHIRIN_SHAHAR
  GULISTON_TUMANI
  BOYOVUT_TUMANI
  SAYXUNOBOD_TUMANI
  MIRZAOBOD_TUMANI
  OQOLTIN_TUMANI
  SARD_OBA_TUMANI
  XOVOS_TUMANI
  SARDOBA_TUMANI
}

//  Users modeli

model Users {
  id                String     @id @default(uuid())
  telegram_id       BigInt     @unique
  first_name        String?
  last_name         String?
  phoneNumber       String?    @unique
  registration_step String?    @default("START") // START, FIRST_NAME, LAST_NAME, PHONE_NUMBER, COMPLETED, REQ_DISTRICT, REQ_ADDRESS, REQ_DESCRIPTION, REQ_PHOTO, REQ_CONFIRM
  
  // Vaqtinchalik ariza ma'lumotlari
  temp_district     District?
  temp_mahalla      String?
  temp_street       String?
  temp_house        String?
  temp_address      String?
  temp_description  String?
  temp_photos       Json?      // Bir nechta rasmlar uchun file_id massivi
  
  role              jekRoles   @default(User)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  requests          Requests[]

  @@map("users")
}

// Admin modeli

model Admins {
  id           String     @id @default(uuid())
  first_name   String     @db.VarChar(50)
  last_name    String     @db.VarChar(50)
  password     String     @db.VarChar(255)
  phoneNumber  String     @unique @db.VarChar(20)
  district     District   // Biriktirilgan hudud
  address      String     @db.VarChar(255)
  role         jekRoles   @default(JEK)
  isActive     Boolean    @default(false)
  refreshToken String?    @db.Text
  jti          String?    @db.VarChar(255)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  assignedRequests Requests[]

  @@map("admins")
}

// Murojaat modeli (Requests)

model Requests {
  id               String      @id @default(uuid())
  request_number   String      @unique @db.VarChar(20)
  user_id          String
  address          String      @db.VarChar(255)
  assigned_jek_id  String?
  latitude         Decimal?    @db.Decimal(10, 8)
  longitude        Decimal?    @db.Decimal(11, 8)
  description      String      @db.Text
  status           Status_Flow @default(PENDING)
  district         District    // Hudud (Enum)
  note             String?     @db.Text
  rejection_reason String?     @db.Text
  completedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assigned_jek      Admins?            @relation(fields: [assigned_jek_id], references: [id])
  user              Users              @relation(fields: [user_id], references: [id])
  requestPhotos     RequestPhoto[]
  requestStatusLogs RequestStatusLog[]

  @@map("requests")
}

// Murojaat rasmlari (RequestPhotos)

model RequestPhoto {
  id         String   @id @default(uuid())
  request_id String
  request    Requests @relation(fields: [request_id], references: [id], onDelete: Cascade)

  file_url         String  @db.Text
  telegram_file_id String? @db.VarChar(255)
  file_size        Int? // Byte-larda

  created_at DateTime @default(now())

  @@map("request_photos")
}

// Holat o'zgarishi loglari (RequestStatusLog)

model RequestStatusLog {
  id              String      @id @default(uuid())
  request_id      String
  request         Requests    @relation(fields: [request_id], references: [id], onDelete: Cascade)
  old_status      Status_Flow
  new_status      Status_Flow
  changed_by_role String      @db.VarChar(50)
  changed_by_id   String      @db.VarChar(50)
  note            String?     @db.Text
  createdAt       DateTime    @default(now())

  @@map("request_status_logs")
}
